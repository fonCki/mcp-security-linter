{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Example custom configuration for JavaScript and TypeScript projects",

  "global": {
    "fileExtensions": [".js", ".ts", ".jsx", ".tsx"],
    "testFilePatterns": [".test.", ".spec.", "__tests__", "/__test__/", "/spec/"],
    "excludePatterns": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/.git/**",
      "**/vendor/**"
    ]
  },

  "analyzers": {
    "command-exec": {
      "enabled": true,
      "severity": "error"
    },
    "token-passthrough": {
      "enabled": true,
      "severity": "warning"
    },
    "unauthenticated-endpoints": {
      "enabled": true,
      "severity": "warning"
    }
  }
}
